{
  "name": "fazade-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev -p 8185",
    "build": "next build",
    "start": "next start -p 8185",
    "lint": "next lint",
    "docker:run": "docker build -t fazade-site . && docker rm -f fazade-dev 2>/dev/null; docker run -d --name fazade-dev -p 8185:8185 -e HOSTNAME=0.0.0.0 fazade-site && echo 'Running at http://localhost:8185'"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.0.0"
  }
}
